{
  "name": "Forgejo",
  "version": "1.0.0",
  "slug": "forgejo",
  "description": "Self-hosted lightweight software forge",
  "url": "https://github.com/simon-adriaanse/hassio-addons/tree/master/forgejo",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "image": "ghcr.io/simon-adriaanse/forgejo-{arch}",
  "map": ["share:rw", "ssl:ro"],
  "ingress": true,
  "ingress_port": 3000,
  "ingress_stream": true,
  "init": false,
  "panel_icon": "mdi:git",
  "panel_title": "Forgejo",
  "options": {
    "domain": "",
    "ssh_port": 22,
    "ssl": false,
    "certfile": "fullchain.pem",
    "keyfile": "privkey.pem"
  },
  "schema": {
    "domain": "str",
    "ssh_port": "int",
    "ssl": "bool",
    "certfile": "str",
    "keyfile": "str"
  },
  "ports": {
    "3000/tcp": 3069,
    "22/tcp": 22
  },
  "ports_description": {
    "3000/tcp": "Web interface (Not required for Ingress)",
    "22/tcp": "SSH for git operations"
  }
}
