{
  "name": "OpenSSL",
  "version": "1.0.0", 
  "slug": "openssl",
  "description": "Generate self-signed certificates",
  "url": "https://github.com/simon-adriaanse/hassio-addons/tree/master/openssl",
  "arch": ["aarch64", "amd64"],
  "image": "ghcr.io/simon-adriaanse/openssl-{arch}",
  "map": ["ssl:rw"],
  "init": false,
  "options": {
